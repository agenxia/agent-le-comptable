{
  "name": "Workflow Agent",
  "description": "Advanced agent with visual workflow engine, triggers, and automated task execution",
  "type": "template",
  "complexity": "advanced",
  "features": [
    "Visual workflow builder",
    "HTTP triggers",
    "Conditional logic",
    "Multi-step automation",
    "Data transformation",
    "Error handling & retry"
  ],
  "env_vars": [
    "AGENT_NAME",
    "AGENT_ID",
    "PLATFORM_URL",
    "PORT",
    "WORKFLOW_TIMEOUT",
    "MAX_RETRIES",
    "LLM_API_KEY",
    "LLM_API_URL"
  ],
  "icon": "⚡",
  "config": {
    "system_prompt": "You are {{AGENT_NAME}}. {{AGENT_DESCRIPTION}}",
    "model": "llama-3.3-70b",
    "temperature": 0.7,
    "max_tokens": 4096
  },
  "methods": [
    {
      "name": "execute",
      "description": "Execute the workflow with given input",
      "params": {
        "input": {
          "type": "object",
          "required": true,
          "description": "Workflow input data"
        }
      },
      "returns": {
        "output": {
          "type": "object",
          "description": "Workflow execution result"
        },
        "steps": {
          "type": "array",
          "description": "Executed step details"
        }
      }
    }
  ],
  "api": [
    {
      "method": "GET",
      "path": "/health",
      "description": "Health check"
    },
    {
      "method": "GET",
      "path": "/.well-known/agent-card.json",
      "description": "Agent discovery card"
    },
    {
      "method": "GET",
      "path": "/docs",
      "description": "API documentation (HTML)"
    },
    {
      "method": "POST",
      "path": "/api/a2a",
      "description": "A2A JSON-RPC 2.0 endpoint"
    }
  ],
  "metadata": {
    "author": "agenxia",
    "source_template": null,
    "type": "template"
  }
}