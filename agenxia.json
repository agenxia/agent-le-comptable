{
  "name": "Workflow Agent",
  "description": "Advanced agent with visual workflow engine, triggers, and automated task execution",
  "type": "template",
  "complexity": "advanced",
  "features": [
    "Visual workflow builder",
    "HTTP triggers",
    "Conditional logic",
    "Multi-step automation",
    "Data transformation",
    "Error handling & retry"
  ],
  "env_vars": [
    "AGENT_NAME",
    "AGENT_ID",
    "PLATFORM_URL",
    "PORT",
    "WORKFLOW_TIMEOUT",
    "MAX_RETRIES",
    "LLM_API_KEY",
    "LLM_API_URL"
  ],
  "icon": "⚡",
  "config": {
    "system_prompt": "You are {{AGENT_NAME}}. {{AGENT_DESCRIPTION}}",
    "model": "llama-3.3-70b",
    "temperature": 0.7,
    "max_tokens": 4096
  }
}